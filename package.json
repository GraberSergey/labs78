{
  "name": "lab8",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "json-server --watch db.json --port 3001 --foreignKeySuffix _fk",
    "typecheck": "vue-tsc -b",
    "test": "vitest --run",
    "test:watch": "vitest",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "json-server": "^0.17.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
